{
  "name": "fff",
  "version": "1.0.0",
  "description": "fff (fucking fucking fast) — a fast terminal AI coding assistant",
  "main": "src/index.tsx",
  "type": "module",
  "bin": {
    "fff": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.tsx --outdir dist --target node",
    "start": "bun run src/index.tsx",
    "dev": "bun --watch src/index.tsx",
    "index": "bun run src/index.tsx index"
  },
  "dependencies": {
    "ink": "^4.4.0",
    "react": "^18.2.0",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^18.2.0",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.0.0"
  }
}
