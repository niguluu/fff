OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-v4-flash

# Optional tuning
# DeepSeek-V4-Flash supports 1M token context window
LLM_TIMEOUT_MS=60000
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=64000

# Safety limits
MAX_TOOL_ROUNDS=20
MAX_CONVERSATION_MESSAGES=40

# Restrict file operations to this directory (defaults to cwd)
WORKING_DIR=/home/balls/fff
