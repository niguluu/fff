OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-v4-flash

# Optional tuning
# DeepSeek-V4-Flash supports 1M token context window
LLM_TIMEOUT_MS=60000
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=64000

# Safety limits
MAX_TOOL_ROUNDS=20
MAX_CONVERSATION_MESSAGES=40

# Restrict file operations to this directory (defaults to cwd)
WORKING_DIR=/home/balls/fff

# run_command tool: per-command timeout and captured-output cap
FFF_COMMAND_TIMEOUT_MS=120000
FFF_MAX_OUTPUT_CHARS=20000

# Codebase indexer (fff index) — cheapest model by default
FFF_INDEX_MODEL=deepseek-chat

# Agent logs (default: ~/.fff/logs). Set FFF_NO_LOG=1 to disable.
# FFF_LOG_DIR=
# FFF_NO_LOG=0
